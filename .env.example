# Core app
APP_NAME=cabras-chat
NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Legacy REST API
API_PREFIX=/api/v1
DB_PATH=/srv/apps/cabras-chat/data/app.db

# Chat auth
CHAT_USERS_FILE=/srv/apps/cabras-chat/config/chat-users.json
TOKEN_SECRET=change-me-with-a-long-random-secret
DEFAULT_ADMIN_USERNAME=Giovanni
DEFAULT_ROOM_NAME=Cabras Chat

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Setup wizard helpers
PUBLIC_HOSTNAME=
SETUP_NETWORK_MODE=lan

# Contact mail
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=

# Telegram notifications for contact form
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
